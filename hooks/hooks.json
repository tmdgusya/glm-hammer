{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/session-start.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Checking for unfinished runs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/route-intent.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Routing intent"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/review-snapshot.js"],
            "timeoutMs": 15000,
            "statusMessage": "(glm-hammer) Binding review source snapshot"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/plan-gate.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Plan integrity gate"
          },
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/token-gate.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Design token gate"
          },
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/deck-gate.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Deck integrity gate"
          },
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/comment-checker.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Checking comments"
          },
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/edit-diagnostics.js"],
            "timeoutMs": 15000,
            "statusMessage": "(glm-hammer) Syntax diagnostics"
          }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/dispatch-log.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Recording dispatch ledger"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/question-observer.js"],
            "timeoutMs": 10000,
            "statusMessage": "(glm-hammer) Observing Stop transcript questions"
          },
          {
            "type": "process",
            "command": "node",
            "args": ["${ZCODE_PLUGIN_ROOT}/hooks/scripts/stop-gate.js"],
            "timeoutMs": 15000,
            "statusMessage": "(glm-hammer) Verifying gates and evidence receipts"
          }
        ]
      }
    ]
  }
}
