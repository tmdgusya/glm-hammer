{
  "color": {
    "text": {
      "default": { "$type": "color", "$value": "#efe7d6" },
      "muted": { "$type": "color", "$value": "#cbbfa8" }
    },
    "surface": {
      "default": { "$type": "color", "$value": "#1a1410" },
      "raised": { "$type": "color", "$value": "#241c15" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "#d97b30" }
    }
  },
  "typography": {
    "font": {
      "display": { "$type": "fontFamily", "$value": ["Georgia", "Times New Roman", "serif"] },
      "mono": { "$type": "fontFamily", "$value": ["Consolas", "Courier New", "monospace"] }
    },
    "size": {
      "title": { "$type": "dimension", "$value": "40px" },
      "body": { "$type": "dimension", "$value": "20px" },
      "caption": { "$type": "dimension", "$value": "14px" }
    }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "32px" }
  },
  "radius": {
    "default": { "$type": "dimension", "$value": "6px" }
  }
}
